# sway config (~/.config/sway/config)

# Variables
set $hyper Ctrl+Mod4
set $left left
set $right right
set $up up
set $down down

# Exec
exec emacs
exec firefox
exec syncthing
exec pipewire
exec pipewire-pulse

# Title Bar
font pango:Iosevka Nerd Font 12
hide_edge_borders smart

# Apps
set $term ghostty
set $menu rofi
set $emacs emacs
set $browser firefox
set $finder nautilus

# Window Focus
bindsym $hyper+$left  focus left
bindsym $hyper+$right focus right
bindsym $hyper+$up    focus up
bindsym $hyper+$down  focus down

# Layout
workspace_layout tabbed
bindsym $hyper+t layout tabbed
bindsym $hyper+e layout toggle split
bindsym $hyper+f fullscreen
bindsym $hyper+w kill
bindsym $hyper+c reload
bindsym $hyper+z floating toggle
bindsym $hyper+b splith
bindsym $hyper+v splitv
bindsym $hyper+a focus parent

# Apps
bindsym $hyper+j      exec swaymsg '[app_id="emacs" workspace="__focused__"] focus' || exec $emacs
bindsym $hyper+k      exec swaymsg '[app_id="Firefox" workspace="__focused__"] focus' || exec $browser
bindsym $hyper+l      exec swaymsg '[app_id="ghostty" workspace="__focused__"] focus' || exec $term
bindsym $hyper+Space  exec rofi -show drun

# Workspaces
bindsym $hyper+1 workspace number 1
bindsym $hyper+2 workspace number 2
bindsym $hyper+3 workspace number 3
bindsym $hyper+4 workspace number 4
bindsym $hyper+5 workspace number 5
bindsym $hyper+6 workspace number 6
bindsym $hyper+7 workspace number 7
bindsym $hyper+8 workspace number 8

# Theme
client.focused          #181818 #565f73 #e4e4ef
client.unfocused        #181818 #282828 #e4e4ef
client.focused_inactive #181818 #282828 #e4e4ef
client.urgent           #453d41 #f43841 #ffffff

# Background
output * bg #181818 solid_color

# Bar
bar {
    position top
    status_command i3status-rs
    font pango:Iosevka Nerd Font 10

    colors {
        background          #181818
        statusline          #e4e4ef
        separator           #453d41
        focused_workspace   #181818 #565f73 #e4e4ef
        active_workspace    #181818 #453d41 #e4e4ef
        inactive_workspace  #181818 #453d41 #e4e4ef
        urgent_workspace    #453d41 #f43841 #ffffff
        binding_mode        #282828 #96a6c8 #e4e4ef
    }
}

# Gestures
bindgesture swipe:3:left  focus prev
bindgesture swipe:3:right focus next

# Audio Controls
bindsym --locked XF86AudioMute        exec wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioMicMute     exec wpctl set-mute   @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness Controls
exec brightnessctl set 90%
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp   exec brightnessctl set 5%+

# Screenshot
bindsym Print exec grim ~/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png
bindsym $hyper+s exec grim -g "$(slurp)" ~/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png

# Keyboard settings
input type:keyboard {
    xkb_layout gb
    xkb_variant mac
    xkb_options altwin:meta_alt
    repeat_rate  36
    repeat_delay 225
}

input "2:1:PS/2_Logitech_Mouse" {
    accel_profile "flat"
    pointer_accel 1.0
    scroll_method on_button_down
    scroll_button 274
}

input "type:touchpad" {
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    click_method clickfinger
}

include ~/.config/sway/config.local
