# sway config (~/.config/sway/config)

# exec
exec_always {
  dbus-update-activation-environment --all

  gsettings set org.gnome.desktop.interface font-name 'Iosevka 14'
  gsettings set org.gnome.desktop.interface monospace-font-name 'Iosevka Nerd Font 14'
  gsettings set org.gnome.desktop.interface document-font-name 'Iosevka 14'
  gsettings set org.gnome.desktop.wm.preferences titlebar-font 'Iosevka Bold 14'
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
  gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
  gsettings set org.gnome.desktop.interface gtk-key-theme 'Emacs'
  gsettings set org.gnome.desktop.interface icon-theme 'Adwaita'
  gsettings set org.gnome.desktop.peripherals.touchpad tap-to-click true
  gsettings set org.gnome.desktop.peripherals.touchpad natural-scroll true
}

exec emacs &
exec firefox &
exec keyd-application-mapper &
exec syncthing &

# Layout
workspace_layout tabbed
font pango:Iosevka Nerd Font 10

# title bar
hide_edge_borders --i3 smart

# Variables
set $hyper Ctrl+Mod4
set $left left
set $right right
set $up up
set $down down

# Apps
set $term foot
set $menu rofi
set $emacs emacs
set $browser firefox
set $finder nautilus

# Window focus
bindsym $hyper+$left focus left
bindsym $hyper+$right focus right
bindsym $hyper+$up focus up
bindsym $hyper+$down focus down

# Layout manipulation
bindsym $hyper+t layout tabbed
bindsym $hyper+e layout toggle split
bindsym $hyper+f fullscreen
bindsym $hyper+w kill
bindsym $hyper+c reload
bindsym $hyper+z floating toggle

# Apps
bindsym $hyper+j exec swaymsg '[app_id="emacs" workspace="__focused__"] focus' || exec $emacs
bindsym $hyper+k exec swaymsg '[app_id="Firefox" workspace="__focused__"] focus' || exec $browser
bindsym $hyper+Return exec $term
bindsym $hyper+Space exec rofi -show drun

# Workspaces
bindsym $hyper+1 workspace number 1
bindsym $hyper+2 workspace number 2
bindsym $hyper+3 workspace number 3
bindsym $hyper+4 workspace number 4
bindsym $hyper+5 workspace number 5
bindsym $hyper+6 workspace number 6
bindsym $hyper+7 workspace number 7
bindsym $hyper+8 workspace number 8

# Background
output * bg #181818 solid_color

# Bar
bar {
    position top
    status_command i3status-rs ~/.config/i3status-rust/config.toml
    font pango:Iosevka Nerd Font 10
    tray_output *
}

# Gestures
bindgesture swipe:3:left  focus prev
bindgesture swipe:3:right focus next

# Audio Controls
bindsym --locked XF86AudioMute        exec pactl set-sink-mute   @DEFAULT_SINK@   toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@   -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@   +5%
bindsym --locked XF86AudioMicMute     exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Brightness controls
exec brightnessctl set 80%
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp   exec brightnessctl set 5%+

# Screenshot
bindsym Print exec grim

# Keyboard settings
input type:keyboard {
    xkb_layout gb
    xkb_variant mac
    xkb_options altwin:meta_alt
    repeat_rate  36
    repeat_delay 225
}

input "2:1:PS/2_Logitech_Mouse" {
    accel_profile "flat"
    pointer_accel 1.0
    scroll_method on_button_down
    scroll_button 274
}

input "type:touchpad" {
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    click_method clickfinger
}

# Laptop
set $laptop eDP-1
bindswitch lid:on output $laptop disable
bindswitch lid:off output $laptop enable
output $laptop disable

include /etc/sway/config.d/*
