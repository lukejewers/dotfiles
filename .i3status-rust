[icons]
icons = "awesome6"

[theme]
theme = "native"

[[block]]
block = "net"
format = " $icon {$ssid ($signal_strength)|$device} "
format_alt = " $icon $ip "
interval = 5

[[block]]
block = "sound"

[[block]]
block = "cpu"
format = "  $utilization "
format_alt = "  $frequency ($barchart) "

[[block]]
block = "memory"
format = "  $mem_used_percents "
format_alt = " $icon_swap $swap_free.eng(w:3,u:B,p:Mi)/$swap_total.eng(w:3,u:B,p:Mi)($swap_used_percents.eng(w:2)) "

[[block]]
block = "backlight"
format = " $icon $brightness "

[[block]]
block = "battery"
format = " $icon $percentage "

[[block]]
block = "time"
format = " 󰃭 $timestamp.datetime(f:'%a %d %b  󰥔 %H:%M') "

[[block.click]]
button = "left"
cmd = "emacsclient -e '(progn (vterm-other-window) (calendar))'"
